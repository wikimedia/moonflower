# Firebase Web Config (Public — safe for client bundle)
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=

# Magic link redirect URL
PUBLIC_AUTH_REDIRECT_URL=http://localhost:5173/verify

# Firebase Admin SDK (Private — server only)
# Paste the full JSON string of your service account key
FIREBASE_SERVICE_ACCOUNT=
