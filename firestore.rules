rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // claimed_cards: Document ID = Wikipedia Page ID (guarantees uniqueness)
    match /claimed_cards/{pageId} {
      // Anyone authenticated can create IF the document doesn't already exist
      allow create: if request.auth != null
                    && !exists(/databases/$(database)/documents/claimed_cards/$(pageId))
                    && request.resource.data.ownerId == request.auth.uid;

      // Only the owner can read or delete their cards
      allow read, delete: if request.auth != null
                          && resource.data.ownerId == request.auth.uid;

      // Cards are immutable once claimed
      allow update: if false;
    }
  }
}
